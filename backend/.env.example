DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Kolkata
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB_NAME=mk_slam_collector
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=http://localhost:5173
JWT_REFRESH_COOKIE_NAME=mk_refresh_token
JWT_REFRESH_COOKIE_SECURE=False
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Production notes:
# - Set DJANGO_DEBUG=False
# - Set FRONTEND_URL, CORS_ALLOWED_ORIGINS, and CSRF_TRUSTED_ORIGINS to your deployed Vercel frontend URL
# - For Vercel preview URLs, you can use CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
# - For split frontend/backend domains, set JWT_REFRESH_COOKIE_SECURE=True and JWT_REFRESH_COOKIE_SAMESITE=None
